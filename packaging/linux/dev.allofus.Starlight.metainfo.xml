  <id>dev.allofus.Starlight</id>
  <name>Starlight</name>
  <summary>Among Us mod manager</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>
  <description>
    <p>
      Starlight is a mod manager and launcher for Among Us. Browse the mod
      catalog, build per-profile mod setups with automatic dependency
      resolution, and launch the game modded via Steam, Epic or Xbox — with
      Wine and Proton support on Linux.
    </p>
