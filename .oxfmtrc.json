{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 100,
	"semi": true,
	"sortTailwindcss": {
		"stylesheet": "./src/app.css",
		"functions": ["clsx", "cn", "cva"]
	},
	"ignorePatterns": ["src-tauri/", ".svelte-kit/", "build/", "static/"]
}
