{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"categories": {
		"correctness": "error",
		"suspicious": "warn",
		"perf": "warn"
	},
	"plugins": ["typescript", "unicorn", "oxc"],
	"env": {
		"browser": true,
		"node": true,
		"es2024": true
	},
	"rules": {
		"no-undef": "off"
	},
	"options": {
		"typeAware": true,
		"typeCheck": true
	},
	"ignorePatterns": ["src-tauri/", ".svelte-kit/", "build/", "static/"]
}
